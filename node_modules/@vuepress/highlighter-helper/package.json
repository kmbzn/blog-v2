{
  "name": "@vuepress/highlighter-helper",
  "version": "2.0.0-rc.131",
  "description": "VuePress Highlighter helper",
  "keywords": [
    "helper",
    "highlighter-helper",
    "vuepress"
  ],
  "homepage": "https://ecosystem.vuejs.press/tools/highlighter-helper/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "tools/highlighter-helper"
  },
  "files": [
    "dist",
    "scss"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/**/*.css",
    "./scss/**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./styles/*.css": "./dist/client/styles/*.css",
    "./scss/*.scss": "./scss/*.scss",
    "./scss/*": {
      "sass": "./scss/*.scss"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@vuepress/helper": "2.0.0-rc.131",
    "@vueuse/core": "^14.3.0",
    "vuepress": "2.0.0-rc.30"
  },
  "peerDependenciesMeta": {
    "@vueuse/core": {
      "optional": true
    }
  },
  "gitHead": "57a09d0808e424fe729d29ef8352d8cff9f30b16"
}
