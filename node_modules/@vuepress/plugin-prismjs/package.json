    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vuepress/helper": "2.0.0-rc.131",
    "@vuepress/highlighter-helper": "2.0.0-rc.131",
    "prismjs": "^1.30.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/prismjs": "^1.26.6",
    "markdown-it": "^14.2.0"
  },
  "peerDependencies": {
    "vuepress": "2.0.0-rc.30"
  },
  "gitHead": "57a09d0808e424fe729d29ef8352d8cff9f30b16"
